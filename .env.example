# ══════════════════════════════════════════════════════════════════════════════
#  ODL Demo — Variables de entorno
#  Copia este archivo a .env y completa los valores. NUNCA subas .env a git.
#      cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── MongoDB (REQUERIDO) ──────────────────────────────────────────────────────
# Cadena de conexión al cluster ODL (donde viven los movimientos ya poblados).
# Pídele a quien te entrega la demo un usuario dedicado con acceso a las bases
# 'bancolombia_odl' e 'iseries_sim'.
MONGODB_ODL_URI="mongodb+srv://USUARIO:PASSWORD@tu-cluster.xxxxx.mongodb.net/"

# Cluster origen para el simulador (opcional; si no lo usas, déjalo igual al de arriba)
MONGODB_URI_ORIGEN="mongodb+srv://USUARIO:PASSWORD@tu-cluster.xxxxx.mongodb.net/"

# ── Claude / Anthropic (OPCIONAL — habilita el chat con IA) ───────────────────
# Consíguela en https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-sonnet-4-6"

# ── Voyage AI (OPCIONAL — búsqueda vectorial / embeddings del chat) ───────────
VOYAGE_API_KEY=""

# ── OpenAI (OPCIONAL — text-to-speech / voz) ─────────────────────────────────
# Consíguela en https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# ── Kafka (OPCIONAL — solo para el simulador en vivo) ────────────────────────
# La app y el dashboard NO necesitan Kafka. Déjalo vacío para deshabilitarlo.
KAFKA_BOOTSTRAP_SERVERS=""
KAFKA_API_KEY=""
KAFKA_API_SECRET=""

# ── Puerto de la API (opcional) ──────────────────────────────────────────────
# API_PORT="8788"
